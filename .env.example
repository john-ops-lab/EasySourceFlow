# Copy this file to .env and fill in local secrets.
# Do not paste API keys or cookies into chat.

EASYSOURCEFLOW_HOST=127.0.0.1
EASYSOURCEFLOW_PORT=8765
EASYSOURCEFLOW_DATA_DIR=~/.local/share/easysourceflow
EASYSOURCEFLOW_OUTPUT_DIR=~/.local/share/easysourceflow/output
EASYSOURCEFLOW_CACHE_TTL_SECONDS=604800
# Normally set automatically by launchd; only needed for a custom runtime copy.
EASYSOURCEFLOW_PROJECT_ROOT=

# macOS LaunchAgent identifiers.
EASYSOURCEFLOW_LAUNCHD_LABEL=app.easysourceflow.daemon
EASYSOURCEFLOW_MAINTENANCE_LABEL=app.easysourceflow.maintenance

# Optional: use a stronger external WeChat-to-Markdown extractor when installed.
# Include {url} where the article URL should be inserted, or omit it to append the URL.
# EASYSOURCEFLOW_WECHAT_MARKDOWN_COMMAND="url-md {url}"
# Optional: set this if Google Chrome is not in the default macOS location.
EASYSOURCEFLOW_CHROME_PATH=

# Bilibili login cookies exported locally.
EASYSOURCEFLOW_BILIBILI_COOKIES_FILE=~/.local/share/easysourceflow/secrets/bilibili-cookies.txt

# YouTube login state. Leave the file empty to use the Web-managed default under DATA_DIR/secrets.
# Import from Chrome in Web maintenance. Configure extractor args only when current yt-dlp guidance requires them.
EASYSOURCEFLOW_YOUTUBE_COOKIES_FILE=
EASYSOURCEFLOW_YOUTUBE_EXTRACTOR_ARGS=

# Local transcription tools.
EASYSOURCEFLOW_FFMPEG_PATH=ffmpeg
EASYSOURCEFLOW_WHISPER_CLI_PATH=whisper-cli
EASYSOURCEFLOW_WHISPER_MODEL_PATH=~/.local/share/easysourceflow/models/ggml-base.bin
EASYSOURCEFLOW_TRANSCRIPTION_BACKEND=whisper_cpp
EASYSOURCEFLOW_MLX_WHISPER_PATH=mlx_whisper
EASYSOURCEFLOW_FASTER_WHISPER_PATH=faster-whisper
EASYSOURCEFLOW_MAX_TRANSCRIPTION_SECONDS=7200

# Summary model provider. Cloud providers use an OpenAI-compatible API.
EASYSOURCEFLOW_MODEL_PROVIDER=openai_compatible
EASYSOURCEFLOW_MODEL=deepseek-v4-flash
EASYSOURCEFLOW_STRONG_MODEL=deepseek-v4-pro
EASYSOURCEFLOW_MODEL_BASE_URL=https://api.deepseek.com
EASYSOURCEFLOW_MODEL_API_KEY=REPLACE_WITH_MODEL_API_KEY

# Shared hard rules and Markdown template for every configured cloud model.
# The Web UI stores multiline content in this local file.
EASYSOURCEFLOW_SUMMARY_PROMPT_FILE=~/.local/share/easysourceflow/config/summary-prompt.txt

# Optional local Agent workspace used only for status checks. Keep real paths in .env, never in tracked files.
EASYSOURCEFLOW_AGENT_WORKSPACE=

# Optional job and maintenance notifications. Events are comma-separated.
# Webhook payloads never include source body, transcript, cookies, or API keys.
EASYSOURCEFLOW_NOTIFICATION_EVENTS=
EASYSOURCEFLOW_NOTIFICATION_WEBHOOK_URL=
EASYSOURCEFLOW_NOTIFICATION_WEBHOOK_TOKEN=
# Command is split into argv and receives JSON on stdin; no shell is used.
EASYSOURCEFLOW_NOTIFICATION_COMMAND=

# Backward-compatible aliases. Prefer EASYSOURCEFLOW_MODEL_* above.
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=
